{
  "name": "morphos-monorepo",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "dev:app": "npm run dev -w apps/app",
    "dev:landing": "npm run dev -w apps/landing",
    "build": "npm run build --workspaces",
    "test": "npm test --workspaces --if-present"
  }
}
